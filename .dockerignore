# Whitelist approach: ignore everything, then allow only what Docker builds need
# This reduces build context from ~900MB to just what's required

# Ignore everything first
*

# === Source build (multi-stage) ===
!package.json
!pnpm-lock.yaml
!pnpm-workspace.yaml
!.npmrc
!tsconfig.json
!patches
!patches/**
!packages
!packages/**
!scripts
!scripts/**

# === n8n main image (docker/images/n8n/Dockerfile) ===
!compiled
!compiled/**
!THIRD_PARTY_LICENSES.md

# === runners image (docker/images/runners/Dockerfile + Dockerfile.distroless) ===
!dist
!dist/task-runner-javascript
!dist/task-runner-javascript/**

# === Docker build files (entrypoints, configs) ===
!docker
!docker/images
!docker/images/n8n
!docker/images/n8n/docker-entrypoint.sh
!docker/images/runners
!docker/images/runners/n8n-task-runners.json

# === Exclude unnecessary files from allowed directories ===
**/.git
**/.gitignore
**/.gitattributes
**/node_modules
**/.turbo
**/.vscode
**/.devcontainer
**/.github
**/.claude
**/coverage
**/*.test.*
**/*.spec.*
**/__tests__
**/__mocks__
**/test
**/tests
**/.storybook
**/storybook
**/*.stories.*
**/*.md
!THIRD_PARTY_LICENSES.md
**/*.map
**/CHANGELOG*
**/LICENSE*
**/.editorconfig
**/.prettierrc*
**/.prettierignore
**/.npmignore
**/biome.jsonc
**/codecov.yml
**/renovate.json
**/lefthook.yml
**/vitest.workspace.ts
**/.actrc
**/.poutine.yml
**/cubic.yaml
**/jest.config.*
**/AGENTS.md
**/CLAUDE.md
